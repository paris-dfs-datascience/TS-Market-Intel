# ── Gemini API key — pick one source ──────────────────────────────
# (1) Direct env var (local dev, quick tests)
GEMINI_API_KEY=your_key_here
#
# (2) Azure Key Vault (preferred in Azure). Leave GEMINI_API_KEY unset and set:
# AZURE_KEY_VAULT_URL=https://<vault>.vault.azure.net/
# GEMINI_API_KEY_SECRET_NAME=gemini-api-key    # default; override if named differently
#
# Resolution order: --api-key arg > GEMINI_API_KEY env > Key Vault.
# Key Vault auth uses DefaultAzureCredential — Managed Identity in Azure,
# `az login` locally. The identity needs "Key Vault Secrets User" on the vault.

# ── Optional — defaults shown ─────────────────────────────────────
# GEMINI_MODEL=gemini-2.5-flash
# DAYS_BACK=30                  # lookback window for signals; set to match your run cadence
# SEMAPHORE_SIZE=13             # max concurrent in-flight API calls per account
# MAX_RETRIES=3                 # attempts per signal before giving up
# SIGNAL_HARD_TIMEOUT=120       # wall-clock kill per signal call (seconds)
# GEMINI_TEMPERATURE=0.2
# MIN_CAPEX_M=50                # minimum capital project value to report ($M)

# ── Output destination ────────────────────────────────────────────
# Azure Blob Storage (preferred for Azure Container Apps). Omit to write locally.
# AZURE_STORAGE_ACCOUNT_URL=https://<account>.blob.core.windows.net
# AZURE_STORAGE_CONTAINER=market-intel-results
#
# Auth uses DefaultAzureCredential:
#   - In Azure Container Apps: the container's Managed Identity (requires
#     "Storage Blob Data Contributor" role on the storage account)
#   - Locally: `az login` credentials, or AZURE_CLIENT_ID/AZURE_CLIENT_SECRET/AZURE_TENANT_ID env vars

# Local output (used when AZURE_STORAGE_ACCOUNT_URL is unset)
# OUTPUT_DIR=./output
